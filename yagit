#!/bin/zsh
source $(dirname "$(readlink -f "$0")")/yagitsh

mode="$1"
src="$2"
repo="$3"
path="$4"

echo "args: $1, $2"

if [ "$4" = "" ]; then
    path="$HOME"
fi
echo "repo: $3"
echo "path: $path"

if [ "$1" = "-c" ]; then
    git clone "https://$2.com/$3 $4"
fi