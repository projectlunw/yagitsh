#!/bin/zsh
source $(dirname "$(readlink -f "$0")")/yagitsh # start yagitsh

mode="$1" # arg, -c : clone
src="$2" # site, github
repo="$3" # repo, projectlunw/yagitsh
path="$4" # path, home/user/

echo "args: $1, $2"

if [ "$4" = "" ]; then
    path="$HOME"
fi
echo "repo: $3"
echo "path: $path"

if [ "$1" = "-c" ]; then
    git clone "https://$2.com/$3" "$4"
fi